# ============================================================
#  Search Papers - AI Academic Paper Search Assistant
#  Configuration File
# ============================================================
#  Copy this file to .env and fill in your API keys:
#    cp .env.example .env
# ============================================================

# DeepSeek API (REQUIRED - for AI analysis & query optimization)
# Get your key at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Scopus API (Optional - skip Scopus search if empty)
# Get your key at: https://dev.elsevier.com/
SCOPUS_API_KEY=your_scopus_key_here

# PubMed API Key (Optional - speeds up PubMed queries)
# Get your key at: https://account.ncbi.nlm.nih.gov/settings/ → API Key Management
PUBMED_API_KEY=your_pubmed_key_here

# Max results per search source (default: 10)
MAX_RESULTS_PER_SOURCE=10
